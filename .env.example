# ============================================
# Coze Bridge Server 환경변수 설정
# 이 파일을 복사해 .env 로 저장한 뒤 실제 값을 채우세요
# 멀티 고객사 환경에서는 clients.json이 우선 사용됩니다
# ============================================

# --- 서버 설정 ---
PORT=8000
ENV=production
LOG_LEVEL=info

# --- 기본 Coze 설정 (clients.json 없을 때 폴백) ---
COZE_BOT_ID=your_bot_id_here
COZE_PAT=your_coze_pat_here
COZE_API_BASE=https://api.coze.com
COZE_TIMEOUT=4.5

# --- 네이버톡톡 설정 (clients.json 없을 때 폴백) ---
NAVER_TALK_PARTNER_ID=your_partner_id_here
NAVER_TALK_TOKEN=your_naver_talk_token_here

# --- 멀티 고객사 설정 ---
CLIENT_CONFIG_JSON=clients.json

# --- 관리자 설정 (선택 — 비워두면 인증 없이 접근 가능) ---
# ADMIN_SECRET=your_admin_secret_here
